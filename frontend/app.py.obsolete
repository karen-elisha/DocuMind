import streamlit as st
import requests
import html
import os
from typing import Dict, Any

API_URL = "http://localhost:8000"

st.set_page_config(
    page_title="DocuMind Workspace",
    page_icon="🧠",
    layout="wide",
    initial_sidebar_state="collapsed",
)

if "messages" not in st.session_state:
    st.session_state.messages = []
if "docs_ingested" not in st.session_state:
    st.session_state.docs_ingested = []
if "theme" not in st.session_state:
    st.session_state.theme = "dark"
if "show_graph" not in st.session_state:
    st.session_state.show_graph = False

# ── Dynamic Theme CSS ─────────────────────────────────────────────────────────

is_light = st.session_state.theme == "light"

css_vars = f"""
    :root {{
        --bg-color: {'#FAFAFA' if is_light else '#0B0F14'};
        --panel-bg: {'#FFFFFF' if is_light else '#111827'};
        --border-color: {'rgba(0,0,0,0.06)' if is_light else 'rgba(255,255,255,0.06)'};
        --text-primary: {'#111827' if is_light else '#F9FAFB'};
        --text-secondary: {'#6B7280' if is_light else '#9CA3AF'};
        --accent: {'#16A34A' if is_light else '#22C55E'};
        --hover-bg: {'rgba(0,0,0,0.03)' if is_light else 'rgba(255,255,255,0.03)'};
        --danger: {'#EF4444' if is_light else '#F87171'};
        --danger-hover: {'#FEE2E2' if is_light else 'rgba(248, 113, 113, 0.1)'};
        --warning: {'#F59E0B' if is_light else '#FBBF24'};
        --warning-bg: {'rgba(245, 158, 11, 0.1)' if is_light else 'rgba(251, 191, 36, 0.1)'};
    }}
"""

st.markdown(f"""
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

{css_vars}

html, body, [class*="css"] {{
