# Weaviate Cloud — console.weaviate.cloud -> your sandbox -> Details
WEAVIATE_URL=https://your-cluster-id.weaviate.network
WEAVIATE_API_KEY=your-weaviate-admin-api-key
WEAVIATE_COLLECTION=DocumentNode

# Groq — console.groq.com -> API Keys (free, no card needed)
GROQ_API_KEY=your-groq-api-key
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Embedding model (local — no API key, runs on your machine)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking
CHUNK_MAX_WORDS=180
CHUNK_OVERLAP_WORDS=30
